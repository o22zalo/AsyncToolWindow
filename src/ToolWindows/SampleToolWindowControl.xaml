<UserControl x:Class="AsyncToolWindowSample.ToolWindows.SampleToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AsyncToolWindowSample.ToolWindows"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="200">

            <!-- Original button -->
            <Button Content="Show VS Location"
                    Click="Button_ShowVsLocation_Click"
                    Width="180"
                    Height="32"
                    Margin="0,0,0,8" />

            <!-- Output Window section -->
            <TextBlock Text="── Output Window ──"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,4"
                       Foreground="Gray" FontSize="11"/>

            <Button Content="Write to Output"
                    Click="Button_WriteOutput_Click"
                    Width="180"
                    Height="32"
                    Margin="0,0,0,8" />

            <Button Content="Clear Output Pane"
                    Click="Button_ClearOutput_Click"
                    Width="180"
                    Height="32"
                    Margin="0,0,0,8" />

            <!-- Status Bar section -->
            <TextBlock Text="── Status Bar ──"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,4"
                       Foreground="Gray" FontSize="11"/>

            <Button Content="Set Status Text"
                    Click="Button_SetStatus_Click"
                    Width="180"
                    Height="32"
                    Margin="0,0,0,8" />

            <Button Content="Animate (3 s)"
                    Click="Button_Animate_Click"
                    Width="180"
                    Height="32"
                    Margin="0,0,0,8" />

            <Button Content="Show Progress Bar"
                    Click="Button_Progress_Click"
                    Width="180"
                    Height="32" />
        </StackPanel>
    </Grid>
</UserControl>
